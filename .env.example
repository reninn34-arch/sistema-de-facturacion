# Backend Proxy Configuration
VITE_BACKEND_URL=http://localhost:3001
VITE_API_KEY=your-api-key-here

# PayPal Configuration
# Para sandbox (pruebas):
VITE_PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
VITE_PAYPAL_SANDBOX=true

# Variables del Backend (usar en .env del backend)
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# En producción, cambiar a tu dominio backend y credenciales de producción
# VITE_BACKEND_URL=https://tu-backend.com
# VITE_API_KEY=clave-api-segura-generada
# PAYPAL_CLIENT_ID=your-paypal-production-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-production-client-secret
# PAYPAL_API_URL=https://api-m.paypal.com
