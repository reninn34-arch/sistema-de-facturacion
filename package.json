{
  "name": "ecuafact-pro---sistema-de-facturación-electrónica",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "dev:backend": "cd backend && npm run dev",
    "build": "vite build",
    "postinstall": "cd backend && npm install && npx prisma generate",
    "vercel-build": "npm run build && cd backend && npx prisma generate && node scripts/migrate-deploy.js",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dompurify": "^3.4.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "node-forge": "^1.3.3",
    "papaparse": "^5.5.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.6.0",
    "soap": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
