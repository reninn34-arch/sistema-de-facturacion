{
  "name": "sri-proxy-server",
  "version": "1.0.0",
  "description": "Backend proxy para conectar con el SRI de Ecuador",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "vercel-build": "prisma generate && node scripts/migrate-deploy.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:blackbox": "jest black-box",
    "test:whitebox": "jest white-box",
    "test:greybox": "jest grey-box",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "db:setup": "node prisma/setup.js",
    "db:consult": "node prisma/consultar-datos.js"
  },
  "keywords": [
    "sri",
    "ecuador",
    "facturacion",
    "soap",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@vonage/server-sdk": "^3.12.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mailgun.js": "^10.4.0",
    "morgan": "^1.10.1",
    "node-fetch": "^2.7.0",
    "node-forge": "^1.3.3",
    "nodemailer": "^8.0.11",
    "soap": "^1.7.1",
    "twilio": "^4.20.0",
    "xml-crypto": "^6.1.2",
    "xml2js": "^0.6.2",
    "@xmldom/xmldom": "^0.9.8"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
