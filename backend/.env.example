# Configuración del Servidor
PORT=3001
NODE_ENV=development

# URL del Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Clave secreta para JWT (cambiar en producción)
JWT_SECRET=tu_jwt_secret_aqui

# Clave API para producción
API_KEY=tu_api_key_aqui

# Clave maestra para cifrar el certificado .p12 y su contraseña en reposo (AES-256-GCM).
# Genérala con:  openssl rand -hex 32
# ⚠️ Si la pierdes/cambias, los certificados guardados no se podrán descifrar (hay que re-subirlos).
CERT_ENCRYPTION_KEY=

# Base de datos (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/database

# SMTP para envío de emails (dejar vacío para modo desarrollo/logs)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@azulpro.com

# PayPal (opcional)
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# Google Gemini AI (opcional)
GEMINI_API_KEY=tu_gemini_api_key

# Configuración Activa de IA
AI_DEFAULT_PROVIDER=deepseek

# DeepSeek (Opcional)
DEEPSEEK_API_KEY=tu_api_key_de_deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenCode Go (Opcional)
OPENCODE_GO_API_KEY=tu_api_key_de_opencode
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# Groq (Opcional)
GROQ_API_KEY=tu_api_key_de_groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
